    {
      "name": "🔐 Autenticação",
      "item": [
        {
          "name": "Registrar Usuário",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"João Silva\",\n  \"email\": \"joao@example.com\",\n  \"tipo_pessoa\": \"F\",\n  \"cpf\": \"123.456.789-00\",\n  \"telefone\": \"55999998888\",\n  \"senha\": \"senha123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "description": "Registra novo usuário.\n\n**tipo_pessoa:**\n- `F` = Pessoa Física (CPF)\n- `J` = Pessoa Jurídica (CNPJ)\n- `N` = Trabalhador (NIT)"
          }
        },
        {
          "name": "Registrar Usuário (CNPJ)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Fazenda Exemplo LTDA\",\n  \"email\": \"fazenda@example.com\",\n  \"tipo_pessoa\": \"J\",\n  \"cnpj\": \"12.345.678/0001-90\",\n  \"telefone\": \"55999997777\",\n  \"senha\": \"senha123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "description": "Registra usuário Pessoa Jurídica"
          }
        },
        {
          "name": "Registrar Usuário (NIT)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Maria Trabalhadora\",\n  \"email\": \"maria@example.com\",\n  \"tipo_pessoa\": \"N\",\n  \"nit\": \"12345678901\",\n  \"telefone\": \"55999996666\",\n  \"senha\": \"senha123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "description": "Registra usuário Trabalhador (NIT)"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access_token) {",
                  "    pm.collectionVariables.set('token', jsonData.access_token);",
                  "    console.log('Token salvo com sucesso!');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              },
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "joao@example.com",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "senha123",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Faz login e retorna token JWT.\n\n**O token é salvo automaticamente na variável `token`**"
          }
        },
        {
          "name": "Usuário Atual",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            },
            "description": "Retorna dados do usuário logado"
          }
        }
      ]
    },
